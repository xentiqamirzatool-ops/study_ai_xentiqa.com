# ─────────────────────────────────────────────────────────────
# StudyAI — environment variables
# Copy to .env.local and fill in. Only NEXT_PUBLIC_* are exposed
# to the browser. Never commit real secrets.
# ─────────────────────────────────────────────────────────────

# Site
NEXT_PUBLIC_SITE_NAME=StudyAI
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Authentication (Clerk) — Stage 7 ──────────────────────────
# https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup

# ── Database (Supabase + Prisma) — Stage 11 ───────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# ── Payments (Stripe) — Stage 10 ──────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── AI provider — Stage 6 ─────────────────────────────────────
# Provider-agnostic; OpenAI by default.
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini
